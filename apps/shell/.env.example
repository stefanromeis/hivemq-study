# MQTT WebSocket endpoint for the browser client.
# Local broker (default): ws://localhost:8000/mqtt
# HiveMQ Cloud:            wss://<cluster>.s1.eu.hivemq.cloud:8884/mqtt
NEXT_PUBLIC_MQTT_WS_URL=ws://localhost:8000/mqtt

# Backend (Java) API base URL.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8081
